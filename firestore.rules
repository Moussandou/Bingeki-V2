rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    // User is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // User matches the requested document ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is an Admin
    function isAdmin() {
      // Security: Relies solely on database role. Ensure your user doc has isAdmin: true.
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Check if the requester can view the target user's private/protected content
    function canViewUserContent(userId) {
      let visibility = get(/databases/$(database)/documents/users/$(userId)).data.profileVisibility;
      return isOwner(userId) || 
             isAdmin() || 
             visibility == 'public' || 
             (visibility == 'friends' && exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid))) ||
             (visibility == null); // Default to public if not set
    }

    // ==================== USERS COLLECTION ====================

    match /users/{userId} {
      // Public Read: Allows Search, Leaderboards, and Admin lists
      allow read: if isAuthenticated();
      
      // Write:
      // 1. Owner can update their profile (bio, theme, etc.)
      // 2. Admin can update ANY profile (for Ban/Promote actions)
      // 3. Prevent Owner from modifying their own 'isAdmin', 'isBanned', or 'createdAt' flags
      allow update: if (isOwner(userId) && 
                        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isBanned', 'createdAt'])) 
                    || isAdmin();

      // Create: Allow users to setup their profile.
      // Delete: Blocked for clients to ensure full cleanup via Auth Extension or Admin SDK.
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
      
      // --- Subcollection: Data (Library & Gamification) ---
      
      // 1. Gamification Data - SERVER-SIDE ONLY
      match /data/gamification {
        allow read: if isAuthenticated();
        // Update: Allow owners to sync their progress/XP 
        // Logic: Prevent regression and excessive jumps (Anti-Cheat)
        allow update: if (isOwner(userId) && (
                           request.resource.data.level >= resource.data.level &&
                           request.resource.data.level <= resource.data.level + 10 &&
                           request.resource.data.totalXp >= resource.data.totalXp &&
                           request.resource.data.totalXp <= resource.data.totalXp + 25000
                         )) || isAdmin();
        allow delete: if isAdmin();
        
        // Owner Create: Allow initial creation only (first login setup)
        allow create: if isOwner(userId);
      }

      // 2. Library Data - Standard Access
      match /data/library {
        allow read: if canViewUserContent(userId);
        allow write: if isOwner(userId) || isAdmin();
      }

      // 3. Other Data - Closed by default for security
      // If you add more documents to /data/, add them explicitly above.

      // --- Subcollection: Friends (Server-side managed) ---
      match /friends/{friendId} {
        // Read: Owner can see their own friends list
        allow read: if isOwner(userId);
        // Write: BLOCKED for clients. All friend management
        // (send/accept/reject) goes through Cloud Functions.
        // Admin SDK bypasses these rules.
      }
      
      // --- Subcollection: Notifications ---
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }

    }

    // ==================== FEATURES ====================

    // FEEDBACK
    match /feedback/{feedbackId} {
      // Anyone can create feedback
      allow create: if isAuthenticated();
      // Users can read their own feedback, Admins can read all
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      // Only Admins can update/delete (Resolution)
      allow update, delete: if isAdmin();
    }

    // WATCH PARTIES
    match /watchparties/{partyId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'lastAction', 'actions']))
      );
      allow delete: if isAuthenticated() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    // ACTIVITY FEED (Server-side managed)
    match /activities/{activityId} {
      // Read: Authenticated users can view the feed IF:
      // 1. They are the owner or an admin
      // 2. OR the activity is explicitly marked as visible (isVisible == true)
      //    AND the profile visibility matches (Public OR is a Friend)
      allow read: if isAuthenticated() && (
                    isOwner(resource.data.userId) || 
                    isAdmin() || 
                    (resource.data.isVisible != false && (
                      resource.data.profileVisibility == 'public' || 
                      resource.data.profileVisibility == null ||
                      (resource.data.profileVisibility == 'friends' && 
                       exists(/databases/$(database)/documents/users/$(resource.data.userId)/friends/$(request.auth.uid)))
                    ))
                  );
      
      // Write: BLOCKED for clients, except for owners deleting their own logs.
      allow create, update: if false; 
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // COMMENTS
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Allow author or Admin to update/delete
      allow update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // CHALLENGES
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }
    
    // ==================== GLOBAL CONFIGURATION ====================
    
    // GLOBAL CONFIG (for announcements, maintenance mode, etc.)
    match /config/{configId} {
      // Allow everyone to read global config (needed for maintenance mode)
      allow read: if true;
      // Only admins can update global config
      allow write: if isAdmin();
    }

    // TIER LISTS
    match /tierLists/{tierListId} {
      // Public lists readable by anyone; private lists only by their author or an admin
      allow read: if resource.data.isPublic == true
                  || (isAuthenticated() && resource.data.userId == request.auth.uid)
                  || isAdmin();

      // Create: Authenticated users can create their own lists
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // Update: Author (full edit) or Admin, or any auth user for likes-only toggle
      allow update: if isAdmin()
                    || (isAuthenticated() && resource.data.userId == request.auth.uid)
                    || (isAuthenticated() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']));

      // Delete: Author or Admin only
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }
    
    // NEWS
    match /news/{newsId} {
      // Public read access for SEO and non-logged users
      allow read: if true;
      // Write access is only allowed for Admin users or the service account
      allow write: if isAdmin();
    }
    
    // SURVEYS
    match /survey_responses/{responseId} {
      allow read: if isAdmin();
      allow create: if true; // Public can submit
      allow update, delete: if isAdmin();
    }

    match /survey_waitlist/{entryId} {
      allow read: if isAdmin();
      allow create: if true; // Public can join waitlist
      allow update, delete: if isAdmin();
    }

    // HEALTH HISTORY
    match /admin_health_history/{historyId} {
      // Only admins can read/write health history
      allow read, write: if isAdmin();
    }

    // REPAIR HISTORY
    match /admin_repair_history/{historyId} {
      // Only admins can read/write repair history (from self-healing scans)
      allow read, write: if isAdmin();
    }

    // ==================== API CACHE (Cloud Functions only) ====================

    // Shared Jikan API cache — readable by all, writable only by Cloud Functions (Admin SDK)
    match /apiCache/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // French translations from Nautiljon — same policy
    match /translations/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ==================== LEGACY / ROOT ACCESS ====================
    // DELETED: Legacy root collections removed for security.
    // All data must go through users/{userId}/data/ subcollections.
  }
}
