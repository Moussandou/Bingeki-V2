rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper: Is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is admin
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Feedback Attachments
    // Path: feedback-attachments/{feedbackId}/{filename}
    match /feedback-attachments/{feedbackId}/{allPaths=**} {
      // Upload: only authenticated users (feedbackId links to their feedback doc)
      allow write: if request.auth != null;
      // Read: admin or the user who submitted the feedback (cross-service Firestore check)
      allow read: if isAdmin() ||
                  (isAuthenticated() &&
                   firestore.get(/databases/(default)/documents/feedback/$(feedbackId)).data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ADMIN BUCKET LISTING (for health checks)
    allow list: if isAdmin();

    // Existing rules for other paths...
    match /avatars/{userId} {
      allow read: if true;
      allow write, list: if isAuthenticated() && request.auth.uid == userId;
      // Allow authenticated users to list files in avatars (needed for some UI components)
      allow list: if isAuthenticated();
    }

    // User personal folder (avatars, covers, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write, list: if request.auth != null && request.auth.uid == userId;
    }
  }
}
